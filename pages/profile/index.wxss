/* profile.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFE4EC 0%, #FFF0F5 50%, #FFE4EC 100%);
  padding: 30rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 105, 180, 0.3);
}

.user-avatar-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid #FFFFFF;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.user-avatar {
  width: 100%;
  height: 100%;
}

.user-info {
  flex: 1;
}

.user-nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.user-openid {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  word-break: break-all;
}

/* 通用 section */
.section {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 182, 193, 0.2);
  border: 2rpx solid #FFE4EC;
  overflow: hidden;
}

.section-title {
  font-size: 28rpx;
  color: #FF69B4;
  font-weight: bold;
  padding: 24rpx 30rpx 16rpx;
}

.section-content {
  padding: 0 30rpx 24rpx;
}

.loading-hint,
.empty-hint {
  text-align: center;
  font-size: 26rpx;
  color: #FFB6C1;
  padding: 30rpx 0;
}

/* 游戏记录 */
.record-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #FFE4EC;
}

.record-item:last-child {
  border-bottom: none;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.record-room {
  font-size: 30rpx;
  font-weight: bold;
  color: #FF69B4;
}

.record-time {
  font-size: 22rpx;
  color: #FFB6C1;
}

.record-players {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

.record-footer {
  display: flex;
  justify-content: space-between;
}

.record-duration {
  font-size: 22rpx;
  color: #999999;
}

.record-reason {
  font-size: 22rpx;
  color: #FF69B4;
}

/* 截图网格 */
.screenshot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.screenshot-item {
  width: calc(50% - 8rpx);
  height: 240rpx;
  border-radius: 16rpx;
  background-color: #FFF0F5;
}

/* 设置 */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #FFE4EC;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 30rpx;
  color: #333333;
}

.setting-arrow {
  font-size: 28rpx;
  color: #FFB6C1;
}
