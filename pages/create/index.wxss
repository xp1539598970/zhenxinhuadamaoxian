/* create.wxss */
.container {
  padding: 40rpx 30rpx;
  background: linear-gradient(180deg, #FFE4EC 0%, #FFF0F5 50%, #FFE4EC 100%);
  min-height: 100vh;
}

.form-item {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 182, 193, 0.2);
  border: 2rpx solid #FFE4EC;
}

.form-label {
  font-size: 28rpx;
  color: #FF69B4;
  margin-bottom: 20rpx;
  font-weight: bold;
}

.form-input {
  font-size: 32rpx;
  color: #FF69B4;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #FFE4EC;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
  color: #FF69B4;
  padding: 20rpx 0;
}

.picker-arrow {
  width: 24rpx;
  height: 24rpx;
}

.create-btn {
  margin-top: 60rpx;
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 100rpx;
  padding: 30rpx;
  border: none;
  box-shadow: 0 8rpx 30rpx rgba(255, 105, 180, 0.4);
}

.create-btn::after {
  border: none;
}
