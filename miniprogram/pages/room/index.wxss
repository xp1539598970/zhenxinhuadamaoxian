/* room.wxss */
.container {
  padding: 40rpx 30rpx;
  background-color: #F5F0FF;
  min-height: 100vh;
}

.room-header {
  background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  color: #FFFFFF;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.room-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.room-code {
  font-size: 26rpx;
  opacity: 0.9;
}

.room-status {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #4ade80;
  border-radius: 50%;
  margin-right: 10rpx;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.players-section {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 20rpx;
}

.players-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.player-card {
  width: calc(25% - 15rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  background-color: #F8F9FA;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  position: relative;
}

.player-card.owner {
  border-color: #8B5CF6;
}

.player-card.current {
  border-color: #EC4899;
  background-color: #FEF2F2;
}

.player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
}

.player-name {
  font-size: 24rpx;
  color: #333333;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.player-tag {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background-color: #8B5CF6;
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
}

.player-tag.current-tag {
  background-color: #EC4899;
  top: -10rpx;
  left: -10rpx;
  right: auto;
}

.players-count {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-top: 20rpx;
}

.question-section {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.question-type {
  font-size: 28rpx;
  font-weight: bold;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

.question-type.truth {
  background-color: #E0E7FF;
  color: #6366F1;
}

.question-type.dare {
  background-color: #FEE2E2;
  color: #EF4444;
}

.question-difficulty {
  font-size: 24rpx;
  color: #999999;
}

.question-content {
  font-size: 36rpx;
  color: #333333;
  text-align: center;
  line-height: 1.6;
  min-height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.question-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  font-size: 30rpx;
  font-weight: bold;
  padding: 25rpx;
  border-radius: 16rpx;
  border: none;
}

.action-btn::after {
  border: none;
}

.skip-btn {
  background-color: #F3F4F6;
  color: #6B7280;
}

.next-btn {
  background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 100%);
  color: #FFFFFF;
}

.waiting-section {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 60rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.waiting-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.waiting-text {
  font-size: 28rpx;
  color: #999999;
}

.actions-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.start-btn {
  background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 100%);
  color: #FFFFFF;
}

.end-btn {
  background-color: #FEE2E2;
  color: #EF4444;
}

.exit-btn {
  background-color: #F3F4F6;
  color: #6B7280;
}

.countdown {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.share-btn {
  background-color: #DBEAFE;
  color: #2563EB;
}

.ask-btn {
  background: linear-gradient(135deg, #F59E0B 0%, #EF4444 100%);
  color: #FFFFFF;
}

.question-meta {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-top: 10rpx;
}

.custom-tag {
  background-color: #FEF3C7;
  color: #D97706;
}

/* 自定义提问弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  max-width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.2);
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
  color: #333333;
}

.modal-section {
  margin-bottom: 25rpx;
}

.modal-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 15rpx;
}

.type-selector {
  display: flex;
  gap: 20rpx;
}

.type-option {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E5E7EB;
  font-size: 28rpx;
  color: #6B7280;
}

.type-option.active-truth {
  background-color: #E0E7FF;
  border-color: #6366F1;
  color: #6366F1;
  font-weight: bold;
}

.type-option.active-dare {
  background-color: #FEE2E2;
  border-color: #EF4444;
  color: #EF4444;
  font-weight: bold;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999999;
}

.ask-textarea {
  width: 100%;
  min-height: 150rpx;
  padding: 20rpx;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-btn {
  flex: 1;
  padding: 25rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.modal-btn::after {
  border: none;
}

.cancel-btn {
  background-color: #F3F4F6;
  color: #6B7280;
}

.submit-btn {
  background: linear-gradient(135deg, #8B5CF6 0%, #EC4899 100%);
  color: #FFFFFF;
}
