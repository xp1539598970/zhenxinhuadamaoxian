/* room.wxss */
.container {
  padding: 20rpx 16rpx;
  background: linear-gradient(180deg, #FFE4EC 0%, #FFF0F5 50%, #FFE4EC 100%);
  min-height: 100vh;
}

.room-header {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  color: #FFFFFF;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 105, 180, 0.3);
}

.room-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.room-code {
  font-size: 26rpx;
  opacity: 0.9;
}

.room-status {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #4ade80;
  border-radius: 50%;
  margin-right: 10rpx;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.players-section {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 182, 193, 0.2);
  border: 2rpx solid #FFE4EC;
}

.section-title {
  font-size: 28rpx;
  color: #FF69B4;
  margin-bottom: 20rpx;
  font-weight: bold;
}

.players-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.player-card {
  width: calc(50% - 8rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  background: linear-gradient(135deg, #FFF5F7 0%, #FFE4EC 100%);
  border-radius: 20rpx;
  border: 2rpx solid #FFB6C1;
  position: relative;
}

.player-card.owner {
  border-color: #FF69B4;
  background: linear-gradient(135deg, #FFE4EC 0%, #FFC0CB 100%);
}

.player-card.current {
  border-color: #FF1493;
  background: linear-gradient(135deg, #FFC0CB 0%, #FFB6C1 100%);
}

.player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
  background-color: #FFFFFF;
  border: 3rpx solid #FFB6C1;
}

.player-avatar-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
  background-color: #FFFFFF;
  border: 3rpx solid #FFB6C1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.player-avatar-emoji {
  font-size: 50rpx;
}

.player-name {
  font-size: 24rpx;
  color: #333333;
  text-align: center;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.2;
}

.player-tag {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: linear-gradient(135deg, #FFB6C1, #FF69B4);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
}

.player-tag.current-tag {
  background: linear-gradient(135deg, #FF69B4, #FF1493);
  top: -10rpx;
  left: -10rpx;
  right: auto;
}

.players-count {
  text-align: center;
  font-size: 24rpx;
  color: #FFB6C1;
  margin-top: 20rpx;
}

.question-section {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 182, 193, 0.2);
  border: 2rpx solid #FFE4EC;
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.question-type {
  font-size: 28rpx;
  font-weight: bold;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

.question-type.truth {
  background: linear-gradient(135deg, #FFE4EC, #FFC0CB);
  color: #FF1493;
}

.question-type.dare {
  background: linear-gradient(135deg, #FFF0F5, #FFB6C1);
  color: #FF69B4;
}

.question-difficulty {
  font-size: 24rpx;
  color: #FF69B4;
}

.question-content {
  font-size: 36rpx;
  color: #333333;
  text-align: center;
  line-height: 1.6;
  min-height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.question-empty {
  text-align: center;
  padding: 40rpx 0 20rpx;
  min-height: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #FF69B4;
}

.action-btn.disabled {
  opacity: 0.6;
}

.question-actions {
  display: flex;
  gap: 8rpx;
  margin-top: 30rpx;
  padding: 0 2rpx;
}

.action-btn {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  font-weight: bold;
  padding: 18rpx 4rpx;
  border-radius: 20rpx;
  text-align: center;
  box-sizing: border-box;
  line-height: 1.4;
}

.skip-btn {
  background: linear-gradient(135deg, #FFE4EC, #FFC0CB);
  color: #FF69B4;
}

.ask-btn {
  background: linear-gradient(135deg, #FFB6C1, #FF69B4);
  color: #FFFFFF;
}

.next-btn {
  background: linear-gradient(135deg, #FF69B4, #FF1493);
  color: #FFFFFF;
}

.waiting-section {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 60rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 182, 193, 0.2);
  border: 2rpx solid #FFE4EC;
  text-align: center;
}

.waiting-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.waiting-text {
  font-size: 28rpx;
  color: #FF69B4;
}

.actions-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.start-btn {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  color: #FFFFFF;
}

.end-btn {
  background-color: #FFE4EC;
  color: #FF1493;
}

.exit-btn {
  background-color: #FFF0F5;
  color: #FF69B4;
}

.countdown {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.5);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.share-btn {
  background-color: #FFE4EC;
  color: #FF69B4;
}

.ask-btn {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  color: #FFFFFF;
}

.question-meta {
  text-align: center;
  font-size: 24rpx;
  color: #FF69B4;
  margin-top: 10rpx;
}

.custom-tag {
  background-color: #FFE4EC;
  color: #FF69B4;
}

/* 自定义提问弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  max-width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(255, 182, 193, 0.3);
  border: 2rpx solid #FFE4EC;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
  color: #FF69B4;
}

.modal-section {
  margin-bottom: 25rpx;
}

.modal-label {
  font-size: 28rpx;
  color: #FF69B4;
  margin-bottom: 15rpx;
}

.type-selector {
  display: flex;
  gap: 20rpx;
}

.type-option {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 2rpx solid #FFE4EC;
  font-size: 28rpx;
  color: #FF69B4;
}

.type-option.active-truth {
  background: linear-gradient(135deg, #FFE4EC, #FFC0CB);
  border-color: #FF69B4;
  color: #FF1493;
  font-weight: bold;
}

.type-option.active-dare {
  background: linear-gradient(135deg, #FFF0F5, #FFB6C1);
  border-color: #FF69B4;
  color: #FF1493;
  font-weight: bold;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid #FFE4EC;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #FF69B4;
}

.picker-arrow {
  font-size: 24rpx;
  color: #FFB6C1;
}

.ask-textarea {
  width: 100%;
  min-height: 150rpx;
  padding: 20rpx;
  border: 2rpx solid #FFE4EC;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-btn {
  flex: 1;
  padding: 25rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.modal-btn::after {
  border: none;
}

.cancel-btn {
  background-color: #FFF0F5;
  color: #FF69B4;
}

.submit-btn {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF69B4 100%);
  color: #FFFFFF;
}

/* 回答状态栏 */
.answer-status-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  margin: 20rpx 0;
  background: linear-gradient(135deg, #FFF0F5, #FFE4EC);
  border-radius: 16rpx;
  border: 2rpx solid #FFB6C1;
}

.typing-dots {
  display: flex;
  gap: 8rpx;
  margin-right: 16rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #FF69B4;
  border-radius: 50%;
  animation: typingBounce 1.4s infinite ease-in-out;
}

.typing-dot:nth-child(1) {
  animation-delay: 0s;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typingBounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.typing-text {
  font-size: 26rpx;
  color: #FF69B4;
  font-weight: bold;
}

.submitted-bar {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  border-color: #81C784;
}

.submitted-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.submitted-text {
  font-size: 26rpx;
  color: #2E7D32;
  font-weight: bold;
}

/* 回答输入区 */
.answer-input-section {
  margin: 30rpx 0;
  padding: 30rpx;
  background: linear-gradient(135deg, #FFF5F7, #FFE4EC);
  border-radius: 20rpx;
  border: 2rpx solid #FFB6C1;
}

.answer-input-label {
  font-size: 28rpx;
  color: #FF69B4;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.answer-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #FFB6C1;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #FFFFFF;
  line-height: 1.6;
}

.answer-input-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.char-count {
  font-size: 24rpx;
  color: #FFB6C1;
}

.char-count.warning {
  color: #FF6B6B;
  font-weight: bold;
}

.answer-submit-btn {
  padding: 16rpx 40rpx;
  background: linear-gradient(135deg, #FFB6C1, #FF69B4);
  color: #FFFFFF;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.answer-submit-btn.disabled {
  opacity: 0.5;
}

/* 等待回答提示 */
.answer-waiting-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  margin: 20rpx 0;
  background: linear-gradient(135deg, #FFF0F5, #FFE4EC);
  border-radius: 16rpx;
  border: 2rpx dashed #FFB6C1;
}

.waiting-emoji {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.waiting-hint-text {
  font-size: 28rpx;
  color: #FF69B4;
}

/* 回答展示区 */
.answer-display-section {
  margin: 30rpx 0;
  padding: 30rpx;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  border-radius: 20rpx;
  border: 2rpx solid #81C784;
}

.answer-display-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.answer-display-label {
  font-size: 28rpx;
  color: #2E7D32;
  font-weight: bold;
}

.answer-display-time {
  font-size: 24rpx;
  color: #66BB6A;
}

.answer-display-content {
  font-size: 32rpx;
  color: #1B5E20;
  line-height: 1.8;
  padding: 20rpx;
  background-color: rgba(255, 255, 255, 0.6);
  border-radius: 12rpx;
  min-height: 100rpx;
}

.answer-display-footer {
  text-align: right;
  margin-top: 20rpx;
}

.answer-from {
  font-size: 26rpx;
  color: #388E3C;
  font-style: italic;
}
