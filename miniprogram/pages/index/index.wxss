/* index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #8B5CF6 0%, #EC4899 100%);
  padding: 60rpx 40rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 80rpx;
  margin-bottom: 80rpx;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 10rpx;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.buttons-section {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 60rpx;
}

.main-btn {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.15);
  border: none;
}

.main-btn::after {
  border: none;
}

.btn-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.btn-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.btn-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 6rpx;
}

.create-btn {
  background: linear-gradient(135deg, #FDE68A 0%, #F59E0B 100%);
}

.create-btn .btn-text {
  color: #FFFFFF;
}

.create-btn .btn-desc {
  color: rgba(255, 255, 255, 0.8);
}

.join-btn {
  background-color: #FFFFFF;
}

.rules-section {
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 40rpx;
  backdrop-filter: blur(10px);
}

.rules-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 30rpx;
  text-align: center;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
}

.rule-num {
  width: 48rpx;
  height: 48rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rule-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.5;
}
