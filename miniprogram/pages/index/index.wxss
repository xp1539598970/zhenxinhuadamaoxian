/* index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFE4EC 0%, #FFF0F5 50%, #FFE4EC 100%);
  padding: 60rpx 40rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 80rpx;
  margin-bottom: 80rpx;
}

.logo-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #FF69B4;
  margin-bottom: 10rpx;
  text-shadow: 0 4rpx 20rpx rgba(255, 105, 180, 0.2);
}

.subtitle {
  font-size: 28rpx;
  color: #FFB6C1;
}

.buttons-section {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 60rpx;
}

.main-btn {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 10rpx 40rpx rgba(255, 182, 193, 0.3);
  border: 2rpx solid #FFE4EC;
}

.main-btn::after {
  border: none;
}

.btn-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.btn-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF69B4;
}

.btn-desc {
  font-size: 24rpx;
  color: #FFB6C1;
  margin-top: 6rpx;
}

.create-btn {
  background: linear-gradient(135deg, #FFE4EC 0%, #FFC0CB 100%);
}

.create-btn .btn-text {
  color: #FF1493;
}

.create-btn .btn-desc {
  color: #FF69B4;
}

.join-btn {
  background-color: #FFFFFF;
}

.rules-section {
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  padding: 40rpx;
  backdrop-filter: blur(10px);
  border: 2rpx solid #FFE4EC;
}

.rules-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF69B4;
  margin-bottom: 30rpx;
  text-align: center;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
}

.rule-num {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FFB6C1, #FF69B4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rule-text {
  font-size: 28rpx;
  color: #FF69B4;
  line-height: 1.5;
}
